GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-pro
USE_VERTEX_AI=true

# If using a service account key mounted in Docker
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/adc.json

SNOW_IMAGE_VERIFY_TLS=false
RESORT_TIMEZONE=America/Denver
SNOW_MIN_INCREMENT_IN=0.1
SNOW_CLEAR_DROP_IN=2.0
SNOW_MIN_CONFIDENCE_FOR_VALID_DEPTH=0.6
SNOW_FORCE_UNREADABLE_ON_POOR_VISIBILITY=true
SNOW_MIN_CONFIDENCE_FOR_INCREMENT=0.85
SNOW_REQUIRE_GOOD_VISIBILITY_FOR_INCREMENT=true
SNOW_MAX_INCREMENT_IN=3.0
SNOW_USE_MOCK_ANALYZER=false

DB_ENABLED=true
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=your-sql-server
DB_DATABASE=ExampleDB
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_HEARTBEAT_HOURS=12
DB_CHANGE_EPSILON_IN=0.05

FETCH_RETRY_ATTEMPTS=2
VERTEX_RETRY_ATTEMPTS=2
RETRY_DELAY_SECONDS=3
LOCK_STALE_MINUTES=120

# Optional email alerts
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=alerts@example.com
ALERT_EMAIL_FROM=snowcam@example.com
ALERT_SUBJECT_PREFIX=SnowCam Alert
ALERT_COOLDOWN_MINUTES=60
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=smtp-password
SMTP_STARTTLS=true
